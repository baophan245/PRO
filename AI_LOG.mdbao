public class GameObject {
    private int x; 
    private int y; 

   
    public GameObject(int x, int y) {
        this.x = x;
        this.y = y;
    }

    // Các phương thức Getter/Setter (Encapsulation) [12, 13]
    public int getX() { return this.x; }
    public int getY() { return this.y; }
    public void setX(int x) { this.x = x; }
    public void setY(int y) { this.y = y; }

    public void display() {
        System.out.println("Object at: " + this.x + ", " + this.y);
    }
}
public class Bird extends GameObject {
    private int velocity;

    public Bird(int x, int y, int velocity) {
        super(x, y);
        this.velocity = velocity;
    }

    
    @Override
    public void display() {
        System.out.println("Bird is flying at height: " + this.getY());
    }

    public void flyUp() {
        this.setY(this.getY() - 15); 
    }
}
public class Pipe extends GameObject {
    private int speed;

    public Pipe(int x, int y, int speed) {
        super(x, y);
        this.speed = speed;
    }

    public void moveLeft() {
        this.setX(this.getX() - this.speed);
    }
public class Main {
    public static void main(String[] args) {

        Bird bird = new Bird(100, 300, 5);
        Pipe pipe = new Pipe(500, 250, 10);

        System.out.println("=== Before Move ===");
        bird.display();
        pipe.display();

        bird.flyUp();
        pipe.moveLeft();

        System.out.println("\n=== After Move ===");
        bird.display();
        pipe.display();
    }
}

