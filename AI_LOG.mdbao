🔹 Main.java
import java.util.ArrayList;

public class Main {

    public static void main(String[] args) {

        ArrayList<GameObject> objectList = new ArrayList<>();

        // Tạo dữ liệu sẵn
        GameObject bird1 = new Bird(100, 200, 20);
        GameObject bird2 = new Bird(150, 250, 15);
        GameObject pipe1 = new Pipe(300, 400, 10);
        GameObject pipe2 = new Pipe(350, 450, 5);

        objectList.add(bird1);
        objectList.add(bird2);
        objectList.add(pipe1);
        objectList.add(pipe2);

        System.out.println("=== Before Move ===");
        for (GameObject obj : objectList) {
            obj.display();
        }

        System.out.println("=== After Move ===");
        for (GameObject obj : objectList) {

            if (obj instanceof Bird) {
                ((Bird) obj).flyUp();
            }

            if (obj instanceof Pipe) {
                ((Pipe) obj).moveLeft();
            }

            obj.display();
        }
    }
}
📌 Các class còn lại giữ nguyên
🔹 GameObject.java
