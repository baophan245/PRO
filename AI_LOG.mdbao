Giải thích thêm về tính đa hình trong dự án Flappy Bird
import java.awt.*;
import java.util.ArrayList;


public class Game {
private ArrayList objectList;
private Bird playerBird;
private Score score;
private Leaderboard leaderboard;
private boolean isLost = false;
private Color birdColor = Color.YELLOW; // Màu mặc định


public Game() {
    initGame();
    leaderboard = new Leaderboard();
}

public void initGame() {
    objectList = new ArrayList<>();
    playerBird = new Bird(100, 250, 0);
    objectList.add(playerBird);
    objectList.add(new Pipe(600, 300, 5));
    objectList.add(new Pipe(900, 250, 5));
    score = new Score();
    isLost = false;
}

public void setBirdColor(Color c) { this.birdColor = c; }

public void update() {
    if (isLost) return;
    playerBird.setVelocity(playerBird.getVelocity() - 1); // Trọng lực
    for (GameObject obj : objectList) {
        obj.move();
        if (obj instanceof Pipe) {
            if (obj.getX() < -50) {
                obj.setX(800);
                score.increment();
                leaderboard.check(score.getValue());
            }
            // Va chạm
            if (playerBird.getX() + 30 > obj.getX() && playerBird.getX() < obj.getX() + 50) {
                if (playerBird.getY() < obj.getY() - 150 || playerBird.getY() > obj.getY() - 30) isLost = true;
            }
        }
    }
    if (playerBird.getY() > 550 || playerBird.getY() < 0) isLost = true;
}

public void jump() { if (!isLost) playerBird.setVelocity(12); }

public void render(Graphics g) {
    g.setColor(new Color(135, 206, 235)); // Bầu trời
    g.fillRect(0, 0, 800, 600);

    for (GameObject obj : objectList) {
        if (obj instanceof Bird) {
            drawBird(g, obj.getX(), obj.getY());
        } else if (obj instanceof Pipe) {
            g.setColor(new Color(34, 139, 34));
            g.fillRect(obj.getX(), obj.getY(), 50, 600);
            g.fillRect(obj.getX(), 0, 50, obj.getY() - 150);
        }
    }

    g.setColor(Color.BLACK);
    g.drawString("Điểm: " + score.getValue(), 20, 30);
    g.drawString("Kỷ lục: " + leaderboard.getHighScore(), 20, 50);
    if (isLost) new GameOver().draw(g, score.getValue());
}

// Hàm vẽ con chim có hình dạng (Mỏ, cánh, mắt)
private void drawBird(Graphics g, int x, int y) {
    Graphics2D g2 = (Graphics2D) g;
    // Thân chim
    g2.setColor(birdColor);
    g2.fillOval(x, y, 35, 30);
    // Cánh
    g2.setColor(Color.WHITE);
    g2.fillOval(x + 5, y + 10, 15, 10);
    // Mắt
    g2.setColor(Color.BLACK);
    g2.fillOval(x + 25, y + 5, 5, 5);
    // Mỏ
    g2.setColor(Color.ORANGE);
    int[] mx = {x + 33, x + 43, x + 33};
    int[] my = {y + 10, y + 15, y + 20};
    g2.fillPolygon(mx, my, 3);
}

}

Dựa trên các quy tắc nghiêm ngặt mà thầy đã dặn dò trong các buổi học (đặc biệt là về từ khóa this., việc sử dụng tiếng Việt không dấu và tính đóng gói), tôi đã chỉnh sửa lại lớp Game của bạn để đảm bảo tuân thủ đúng yêu cầu và không bị trừ điểm.
Các điểm chính đã được sửa đổi:
Bắt buộc dùng this.: Thêm this. trước tất cả các thuộc tính của lớp (như this.objectList, this.playerBird, this.isLost,...) trong mọi phương thức
.
Tuyệt đối không dùng tiếng Việt có dấu: Toàn bộ các chuỗi hiển thị trên màn hình (drawString) và các đoạn chú thích (comment) đã được chuyển sang tiếng Anh hoặc tiếng Việt không dấu để tránh lỗi công cụ chấm bài tự động
.
Tối ưu hóa tính Đa hình: Việc bạn sử dụng ArrayList<GameObject> và gọi obj.move() là rất tốt, thể hiện đúng tính đa hình mà thầy yêu cầu
.
Đoạn code đã chỉnh sửa:
import java.awt.*;
import java.util.ArrayList;

public class Game {
    // Attributes must be private
    private ArrayList<GameObject> objectList;
    private Bird playerBird;
    private Score score;
    private Leaderboard leaderboard;
    private boolean isLost = false;
    private Color birdColor = Color.YELLOW; // Default color

    public Game() {
        this.initGame();
        this.leaderboard = new Leaderboard();
    }

    public void initGame() {
        this.objectList = new ArrayList<>();
        this.playerBird = new Bird(100, 250, 0); 
        this.objectList.add(this.playerBird);
        this.objectList.add(new Pipe(600, 300, 5));
        this.objectList.add(new Pipe(900, 250, 5));
        this.score = new Score();
        this.isLost = false;
    }

    public void setBirdColor(Color c) { 
        this.birdColor = c; 
    }

    public void update() {
        if (this.isLost) return;
        
        // Use this. for attributes and gravity logic
        this.playerBird.setVelocity(this.playerBird.getVelocity() - 1); 
        
        for (GameObject obj : this.objectList) {
            obj.move(); // Polymorphism: Call correct move() of Bird or Pipe
            
            if (obj instanceof Pipe) {
                if (obj.getX() < -50) { 
                    obj.setX(800); 
                    this.score.increment();
                    this.leaderboard.check(this.score.getValue());
                }
                // Collision logic using this.
                if (this.playerBird.getX() + 30 > obj.getX() && this.playerBird.getX() < obj.getX() + 50) {
                    if (this.playerBird.getY() < obj.getY() - 150 || this.playerBird.getY() > obj.getY() - 30) {
                        this.isLost = true;
                    }
                }
            }
        }
        
        // Screen boundary check
        if (this.playerBird.getY() > 550 || this.playerBird.getY() < 0) {
            this.isLost = true;
        }
    }

    public void jump() { 
        if (!this.isLost) {
            this.playerBird.setVelocity(12); 
        }
    }

    public void render(Graphics g) {
        // Sky color
        g.setColor(new Color(135, 206, 235)); 
        g.fillRect(0, 0, 800, 600);

        for (GameObject obj : this.objectList) {
            if (obj instanceof Bird) {
                // Using helper method to draw bird
                this.drawBird(g, obj.getX(), obj.getY());
            } else if (obj instanceof Pipe) {
                g.setColor(new Color(34, 139, 34));
                g.fillRect(obj.getX(), obj.getY(), 50, 600);
                g.fillRect(obj.getX(), 0, 50, obj.getY() - 150);
            }
        }
        
        // Display score in English/No accent to avoid errors
        g.setColor(Color.BLACK);
        g.drawString("Score: " + this.score.getValue(), 20, 30);
        g.drawString("High Score: " + this.leaderboard.getHighScore(), 20, 50);
        
        if (this.isLost) {
            new GameOver().draw(g, this.score.getValue());
        }
    }

    // Drawing method for Bird shape (Beak, wings, eyes)
    private void drawBird(Graphics g, int x, int y) {
        Graphics2D g2 = (Graphics2D) g;
        // Body
        g2.setColor(this.birdColor);
        g2.fillOval(x, y, 35, 30);
        // Wings
        g2.setColor(Color.WHITE);
        g2.fillOval(x + 5, y + 10, 15, 10);
        // Eyes
        g2.setColor(Color.BLACK);
        g2.fillOval(x + 25, y + 5, 5, 5);
        // Beak
        g2.setColor(Color.ORANGE);
        int[] mx = {x + 33, x + 43, x + 33};
        int[] my = {y + 10, y + 15, y + 20};
        g2.fillPolygon(mx, my, 3);
    }
}
Lưu ý quan trọng cho bài thuyết trình:
Giải thích tính Đa hình: Khi thầy hỏi về dòng obj.move(), hãy trả lời: "Dù danh sách objectList có kiểu là GameObject, nhưng nhờ tính Đa hình, chương trình sẽ tự động gọi đúng hàm move() của lớp con tương ứng (Bird hoặc Pipe) mà không cần dùng if-else phức tạp"
.
Chia đôi màn hình: Khi demo, hãy mở Sơ đồ lớp (Class Diagram) một bên và Code một bên để thầy thấy sự thống nhất
.
