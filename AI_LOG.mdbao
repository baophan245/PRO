import javax.swing.;
import java.awt.;
import java.awt.event.*;


public class GameWindow extends JFrame implements KeyListener {
private Game game;


public GameWindow() {
    game = new Game();
    setTitle("Flappy Bird Custom");
    setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);

    JPanel gamePanel = new JPanel() {
        @Override
        protected void paintComponent(Graphics g) {
            super.paintComponent(g);
            game.render(g);
        }
    };
    gamePanel.setPreferredSize(new Dimension(800, 600));

    // Thanh chọn màu
    JPanel colorPanel = new JPanel();
    colorPanel.add(new JLabel("Chọn màu chim: "));
    String[] colors = {"Vàng", "Đỏ", "Xanh", "Hồng"};
    Color[] colorValues = {Color.YELLOW, Color.RED, Color.CYAN, Color.PINK};

    for (int i = 0; i < colors.length; i++) {
        JButton btn = new JButton(colors[i]);
        final int index = i;
        btn.addActionListener(e -> {
            game.setBirdColor(colorValues[index]);
            gamePanel.requestFocusInWindow();
        });
        btn.setFocusable(false);
        colorPanel.add(btn);
    }

    add(gamePanel, BorderLayout.CENTER);
    add(colorPanel, BorderLayout.SOUTH);
    pack();

    gamePanel.setFocusable(true);
    gamePanel.addKeyListener(this);
    setLocationRelativeTo(null);

    new Thread(() -> {
        while (true) {
            game.update();
            gamePanel.repaint();
            try { Thread.sleep(25); } catch (Exception e) {}
        }
    }).start();
}

@Override
public void keyPressed(KeyEvent e) {
    if (e.getKeyCode() == KeyEvent.VK_SPACE) game.jump();
    if (e.getKeyCode() == KeyEvent.VK_R) game.initGame();
}
public void keyReleased(KeyEvent e) {}
public void keyTyped(KeyEvent e) {}

public static void main(String[] args) {
    new GameWindow().setVisible(true);
}

}

Dựa trên những quy tắc nghiêm ngặt mà thầy đã dặn dò trong các buổi học, tôi đã rà soát và chỉnh sửa đoạn code GameWindow của bạn. Dưới đây là các điểm cần lưu ý và bản mã nguồn đã hoàn thiện:
Các lỗi cần sửa theo yêu cầu của thầy:
Bắt buộc dùng this.: Thầy yêu cầu tất cả các biến thuộc tính (attribute) và phương thức khi sử dụng trong lớp phải có từ khóa this. phía trước để phân biệt rõ ràng
.
Tuyệt đối không dùng tiếng Việt có dấu: Thầy cảnh báo các công cụ chấm điểm tự động và JDK 1.8 rất nhạy cảm với ký tự có dấu, có thể gây lỗi biên dịch hoặc mất điểm
. Các chuỗi như "Chọn màu chim", "Vàng", "Đỏ"... phải được chuyển sang tiếng Anh hoặc tiếng Việt không dấu.
Truy cập thuộc tính trong lớp nội (Inner Class): Khi ở trong một Thread hoặc ActionListener, bạn nên dùng GameWindow.this.game để chỉ định rõ thuộc tính của lớp bao ngoài, tuân thủ đúng tinh thần "máy móc" nhưng an toàn của thầy
.
Đoạn code đã chỉnh sửa:
import javax.swing.*;
import java.awt.*;
import java.awt.event.*;

public class GameWindow extends JFrame implements KeyListener {
    // Attributes must be private
    private Game game;

    public GameWindow() {
        // Use this. for attributes and methods
        this.game = new Game();
        this.setTitle("Flappy Bird Custom");
        this.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        
        JPanel gamePanel = new JPanel() {
            @Override
            protected void paintComponent(Graphics g) {
                super.paintComponent(g);
                // Refer to outer class attribute using this.
                GameWindow.this.game.render(g);
            }
        };
        gamePanel.setPreferredSize(new Dimension(800, 600));

        // Color selection panel - All strings in English or no accents
        JPanel colorPanel = new JPanel();
        colorPanel.add(new JLabel("Select bird color: "));
        
        String[] colors = {"Yellow", "Red", "Cyan", "Pink"};
        Color[] colorValues = {Color.YELLOW, Color.RED, Color.CYAN, Color.PINK};
        
        for (int i = 0; i < colors.length; i++) {
            JButton btn = new JButton(colors[i]);
            final int index = i;
            btn.addActionListener(new ActionListener() {
                @Override
                public void actionPerformed(ActionEvent e) {
                    // Using this. to access outer class methods/attributes
                    GameWindow.this.game.setBirdColor(colorValues[index]);
                    gamePanel.requestFocusInWindow();
                }
            });
            btn.setFocusable(false);
            colorPanel.add(btn);
        }

        this.add(gamePanel, BorderLayout.CENTER);
        this.add(colorPanel, BorderLayout.SOUTH);
        this.pack();
        
        gamePanel.setFocusable(true);
        gamePanel.addKeyListener(this);
        this.setLocationRelativeTo(null);

        // Game Loop Thread
        new Thread(new Runnable() {
            @Override
            public void run() {
                while (true) {
                    GameWindow.this.game.update();
                    gamePanel.repaint();
                    try { 
                        Thread.sleep(25); 
                    } catch (Exception e) {
                        // Standard error handling without Vietnamese
                    }
                }
            }
        }).start();
    }

    @Override
    public void keyPressed(KeyEvent e) {
        if (e.getKeyCode() == KeyEvent.VK_SPACE) {
            this.game.jump();
        }
        if (e.getKeyCode() == KeyEvent.VK_R) {
            this.game.initGame();
        }
    }

    @Override
    public void keyReleased(KeyEvent e) {}

    @Override
    public void keyTyped(KeyEvent e) {}

    public static void main(String[] args) {
        // Run the window
        new GameWindow().setVisible(true);
    }
}
Lời khuyên khi trình bày:
Định dạng code: Hãy sử dụng tính năng Format (Chuột phải -> Format) trong NetBeans để các dấu ngoặc và lùi đầu dòng ngay ngắn
.
Giải thích từ khóa: Nếu thầy hỏi tại sao dùng GameWindow.this.game, hãy trả lời rằng đó là để đảm bảo truy cập đúng thuộc tính của lớp hiện tại từ bên trong một lớp nội hoặc luồng (thread)
.
Chia đôi màn hình: Khi thuyết trình, bạn nhớ mở một bên là code và một bên là sơ đồ lớp (Class Diagram) để thầy thấy sự thống nhất
.
Bạn có muốn tôi giúp bạn soạn sẵn các câu trả lời cho phần vấn đáp về tính đa hình trong danh sách objectList của lớp Game không?
