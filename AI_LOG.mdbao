        java.awt.EventQueue.invokeLater(() -> {
            new GameWindow().setVisible(true);
        });
    }
}
Cách để chạy game:
Bây giờ dự án của bạn đã có đủ 7 file như hình.

Nếu bạn nhấn chuột phải vào Main.java và chọn Run File, nó sẽ in ra màn hình Console chữ "=== Before Move ===" y như cũ.

Nếu bạn nhấn chuột phải vào GameWindow.java và chọn Run File, một cửa sổ game sẽ hiện ra và bạn sẽ thấy các chấm đỏ (Chim) và cột xanh (Ống) bay ngang màn hình.

Bạn có muốn tôi hướng dẫn cách đổi màu nền cho cửa sổ game thành màu xanh da trời cho giống thật không?

Bạn đã nói
sao nó không chạy ra game nhảy nhảy luôn trời

Gemini đã nói
Hiểu ý bạn rồi! Sở dĩ nó chưa "nhảy nhảy" giống Flappy Bird thật là vì tôi đã phải giữ nguyên 100% code cũ của bạn theo đúng yêu cầu.

Trong code Bird.java cũ của bạn, con chim chỉ có một cái velocity (vận tốc) cố định và hàm move() chỉ đơn giản là trừ dần tọa độ Y (y = y - velocity). Nó không có trọng lực (để rớt xuống) và cũng chưa có bắt sự kiện bàn phím (để bấm phím Space cho nó bay lên).

Nhưng không sao, chúng ta vẫn không cần sửa code cũ của bạn. Tôi sẽ thêm "trọng lực" và "sự kiện bấm phím Space" vào 2 file mới là Game.java và GameWindow.java để nó thành game thật sự nhé.

Dưới đây là bản cập nhật cho 2 file đó để bạn có thể chơi được:

1. Game.java (Thêm trọng lực và hàm nhảy)
Copy đoạn code này đè lên file Game.java cũ. Tôi đã thiết lập để chim rớt xuống liên tục, và thay đổi cách vẽ ống cống để có khe hở cho chim bay qua.

Java
import java.awt.Color;
import java.awt.Graphics;
import java.util.ArrayList;

public class Game {
    private ArrayList<GameObject> objectList;
    private Bird playerBird;

    public Game() {
        objectList = new ArrayList<>();
        
        // Tạo 1 con chim làm người chơi (Vận tốc ban đầu = 0)
        playerBird = new Bird(100, 200, 0); 
        objectList.add(playerBird);
        
        // Tạo các ống cống chạy tới
        objectList.add(new Pipe(500, 300, 5));
        objectList.add(new Pipe(800, 250, 5));
    }

    public void update() {
        // 1. TRỌNG LỰC: Làm cho vận tốc chim giảm dần để nó rớt xuống
        // Hàm move() của bạn là: y = y - velocity. 
        // Vận tốc âm thì rớt xuống, vận tốc dương thì bay lên.
        playerBird.setVelocity(playerBird.getVelocity() - 1);

        for (GameObject obj : objectList) {
            obj.move(); // Vẫn dùng hàm move() gốc của bạn
            
            // 2. Lặp lại ống cống khi nó chạy khuất màn hình (tạo cảm giác bay mãi mãi)
            if (obj instanceof Pipe && obj.getX() < -50) {
                obj.setX(800);
            }
        }
        
        // 3. Chặn không cho chim rớt lủng đáy màn hình
        if (playerBird.getY() > 520) {
            playerBird.setY(520);
        }
    }

    // Hàm gọi khi bấm phím Space
    public void jump() {
        playerBird.setVelocity(12); // Bơm vận tốc dương lớn để chim giật lên trên
    }

    public void render(Graphics g) {
        // Vẽ bầu trời (Nền xanh)
        g.setColor(new Color(135, 206, 235));
        g.fillRect(0, 0, 800, 600);

        for (GameObject obj : objectList) {
            if (obj instanceof Bird) {
                g.setColor(Color.RED);
                g.fillOval(obj.getX(), obj.getY(), 30, 30); // Vẽ con chim
            } else if (obj instanceof Pipe) {
                g.setColor(Color.GREEN);
                // Vẽ ống cống dưới
                g.fillRect(obj.getX(), obj.getY(), 50, 600 - obj.getY());
                // Vẽ ống cống trên (chừa 1 khe hở 150px cho chim bay qua)
                g.fillRect(obj.getX(), 0, 50, obj.getY() - 150);
            }
        }
    }
}
2. GameWindow.java (Thêm bắt sự kiện bàn phím)
Copy đoạn code này đè lên GameWindow.java. Nó đã được thêm KeyListener để lắng nghe phím bấm của bạn.

Java
import javax.swing.JFrame;
import javax.swing.JPanel;
import java.awt.Graphics;
import java.awt.event.KeyEvent;
import java.awt.event.KeyListener;

public class GameWindow extends JFrame implements KeyListener {
    private Game game;

    public GameWindow() {
        game = new Game();
        setTitle("Flappy Bird - Bấm SPACE để bay!");
        setSize(800, 600);
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        setLocationRelativeTo(null);

        JPanel panel = new JPanel() {
            @Override
            protected void paintComponent(Graphics g) {
                super.paintComponent(g);
                game.render(g);
            }
        };
        add(panel);

        // Kích hoạt lắng nghe bàn phím
        addKeyListener(this);
        setFocusable(true);

        // Vòng lặp game
        new Thread(() -> {
            while (true) {
                game.update();
                panel.repaint();
                try {
                    Thread.sleep(30); // Giúp game mượt hơn
                } catch (InterruptedException e) {
                    e.printStackTrace();
                }
            }
        }).start();
    }

    // --- CÁC HÀM XỬ LÝ BÀN PHÍM ---
    @Override
    public void keyPressed(KeyEvent e) {
        if (e.getKeyCode() == KeyEvent.VK_SPACE) {
            game.jump(); // Gọi con chim nhảy lên khi đập phím Space
        }
    }

    @Override
    public void keyReleased(KeyEvent e) {}

    @Override
    public void keyTyped(KeyEvent e) {}

    // Chạy game tại đây (Không cần đụng tới Main.java cũ)
    public static void main(String[] args) {
        java.awt.EventQueue.invokeLater(() -> {
            new GameWindow().setVisible(true);
        });
    }
}
Cách chơi bây giờ:

Vẫn KHÔNG đụng tới Bird.java, Pipe.java, GameObject.java hay Main.java của bạn.

Chuột phải vào file GameWindow.java -> Chọn Run File.

Khi màn hình hiện lên, nhấn phím SPACE liên tục để thấy cục màu đỏ (chim) nảy lên và lách qua các khe hở của cột màu xanh nhé!

Hiện tại chim đụng vào cột xanh chưa chết, bạn có muốn tôi thêm tính năng "Đụng ống cống là Game Over" cho hoàn chỉnh không?

Bạn đã nói
thêm class điểm số class thua game và class bảng xếp hạng nữa

Gemini đã nói
Để hoàn thiện dự án theo đúng cấu trúc hình ảnh bạn cung cấp và thêm các tính năng: Điểm số, Màn hình thua cuộc, và Bảng xếp hạng mà vẫn giữ nguyên 100% code cũ của các class Bird, Pipe, GameObject, và Main, chúng ta cần bổ sung thêm các lớp quản lý logic mới.

Dưới đây là mã nguồn chi tiết cho từng class mới:

1. Score.java (Quản lý điểm số)
Lớp này dùng để lưu trữ và tăng điểm khi chim vượt qua ống cống.

Java
public class Score {
    private int currentScore;

    public Score() {
        this.currentScore = 0;
    }

    public void increment() {
        this.currentScore++;
    }

    public int getValue() {
        return this.currentScore;
    }

    public void reset() {
        this.currentScore = 0;
    }
}
2. GameOver.java (Màn hình thua cuộc)
Lớp này xử lý trạng thái khi chim va chạm hoặc rơi xuống đất.

Java
import java.awt.*;

public class GameOver {
    private boolean isGameOver = false;

    public void setGameOver(boolean status) {
        this.isGameOver = status;
    }

    public boolean isGameOver() {
        return this.isGameOver;
    }

    public void draw(Graphics g, int width, int height) {
        if (isGameOver) {
            g.setColor(new Color(0, 0, 0, 150)); // Màn hình mờ đen
            g.fillRect(0, 0, width, height);
            
            g.setColor(Color.WHITE);
            g.setFont(new Font("Arial", Font.BOLD, 50));
            g.drawString("GAME OVER", width / 2 - 150, height / 2);
            
            g.setFont(new Font("Arial", Font.PLAIN, 20));
            g.drawString("Press 'R' to Restart", width / 2 - 80, height / 2 + 50);
        }
    }
}
3. Leaderboard.java (Bảng xếp hạng)
Lớp này lưu giữ điểm cao nhất trong phiên chơi.

Java
import java.util.ArrayList;
import java.util.Collections;

public class Leaderboard {
    private ArrayList<Integer> scores;

    public Leaderboard() {
        scores = new ArrayList<>();
    }

    public void addScore(int score) {
        scores.add(score);
        Collections.sort(scores, Collections.reverseOrder());
    }

    public int getHighScore() {
        return scores.isEmpty() ? 0 : scores.get(0);
    }
}
4. Cập nhật Game.java (Logic va chạm và Điểm)
Chúng ta đưa các lớp trên vào Game.java để điều khiển toàn bộ trò chơi.

Java
import java.awt.*;
import java.util.ArrayList;

public class Game {
    private ArrayList<GameObject> objectList;
    private Bird playerBird;
    private Score score;
    private GameOver gameOver;
    private Leaderboard leaderboard;

    public Game() {
        initGame();
        leaderboard = new Leaderboard();
    }

    public void initGame() {
        objectList = new ArrayList<>();
        playerBird = new Bird(100, 250, 0); // Bird từ code cũ của bạn
        objectList.add(playerBird);
        objectList.add(new Pipe(600, 300, 5)); // Pipe từ code cũ của bạn
        objectList.add(new Pipe(900, 200, 5));
        score = new Score();
        gameOver = new GameOver();
    }

    public void jump() {
        if (!gameOver.isGameOver()) {
            playerBird.setVelocity(10); // Nhảy lên
        } else {
            initGame(); // Reset game nếu đang ở màn hình thua
        }
    }

    public void update() {
        if (gameOver.isGameOver()) return;

        // Trọng lực làm chim rơi
        playerBird.setVelocity(playerBird.getVelocity() - 1);

        for (GameObject obj : objectList) {
            obj.move(); // Sử dụng move() gốc của bạn

            if (obj instanceof Pipe) {
                // Check va chạm cơ bản
                if (playerBird.getX() < obj.getX() + 50 && playerBird.getX() + 30 > obj.getX()) {
                    if (playerBird.getY() < obj.getY() - 150 || playerBird.getY() > obj.getY() - 30) {
                        endGame();
                    }
                }
                // Tính điểm khi qua ống
                if (obj.getX() == 100) score.increment();
                // Lặp lại ống
                if (obj.getX() < -50) obj.setX(800);
            }
        }

        if (playerBird.getY() > 550 || playerBird.getY() < 0) endGame();
    }

    private void endGame() {
        gameOver.setGameOver(true);
        leaderboard.addScore(score.getValue());
    }

    public void render(Graphics g) {
        // Nền sky
        g.setColor(new Color(135, 206, 235));
        g.fillRect(0, 0, 800, 600);

        for (GameObject obj : objectList) {
            if (obj instanceof Bird) {
                g.setColor(Color.RED);
                g.fillOval(obj.getX(), obj.getY(), 30, 30);
            } else if (obj instanceof Pipe) {
                g.setColor(Color.GREEN);
                g.fillRect(obj.getX(), obj.getY(), 50, 600); // Ống dưới
                g.fillRect(obj.getX(), 0, 50, obj.getY() - 150); // Ống trên
            }
        }

        // Hiển thị điểm và kỷ lục
        g.setColor(Color.BLACK);
        g.setFont(new Font("Arial", Font.BOLD, 20));
        g.drawString("Score: " + score.getValue(), 20, 30);
        g.drawString("High Score: " + leaderboard.getHighScore(), 20, 60);

        gameOver.draw(g, 800, 600);
    }
}
5. GameWindow.java (Khởi chạy)
Vẫn dùng phím Space để nhảy và phím R để chơi lại.

Java
import javax.swing.*;
import java.awt.event.*;

public class GameWindow extends JFrame implements KeyListener {
    private Game game;

    public GameWindow() {
        game = new Game();
        setTitle("Flappy Bird Complete");
        setSize(800, 600);
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        addKeyListener(this);
        
        JPanel panel = new JPanel() {
            @Override
            protected void paintComponent(java.awt.Graphics g) {
                super.paintComponent(g);
                game.render(g);
            }
        };
        add(panel);

        new Thread(() -> {
            while (true) {
                game.update();
                panel.repaint();
                try { Thread.sleep(25); } catch (Exception e) {}
            }
        }).start();
    }

    @Override
    public void keyPressed(KeyEvent e) {
        if (e.getKeyCode() == KeyEvent.VK_SPACE) game.jump();
        if (e.getKeyCode() == KeyEvent.VK_R) game.initGame();
    }
    public void keyReleased(KeyEvent e) {}
    public void keyTyped(KeyEvent e) {}

    public static void main(String[] args) {
        new GameWindow().setVisible(true);
    }
}
Tổng kết: Bây giờ dự án của bạn có đầy đủ các file theo yêu cầu. Bạn chỉ cần chạy file GameWindow.java để chơi. Mọi logic di chuyển của Bird và Pipe vẫn đang sử dụng chính xác các hàm move() mà bạn đã viết trong code gốc.

Bạn đã nói
bây giờ tôi muốn có ngoại hình con chim luôn và có thể chọn màu cho nó

Gemini đã nói
Tuyệt vời! Bạn muốn nâng cấp con chim từ một hình tròn đỏ đơn giản thành một hình ảnh con chim thực thụ và có thể tùy chọn màu sắc. Đây là một bước tiến lớn để làm cho trò chơi của bạn trông chuyên nghiệp hơn.

Để thực hiện việc này mà vẫn giữ nguyên 100% code cũ của bạn (các class Bird, Pipe, GameObject, và Main), chúng ta sẽ không sửa đổi bất kỳ file nào trong số đó. Thay vào đó, chúng ta sẽ tập trung sửa đổi lớp Game (nơi xử lý việc vẽ) và thêm một lớp mới để quản lý việc chọn màu.

Dưới đây là các bước chi tiết:

1. Thêm hình ảnh con chim
Bạn cần chuẩn bị một tệp hình ảnh con chim (ví dụ: bird.png) và đặt nó vào cùng thư mục với các file Java của bạn (hoặc một thư mục hình ảnh riêng).

2. Sửa đổi Game.java để vẽ hình ảnh và hỗ trợ đổi màu
Chúng ta sẽ thay đổi phương thức render trong Game.java để vẽ hình ảnh thay vì hình tròn. Đồng thời, chúng ta sẽ thêm một thuộc tính để lưu màu sắc được chọn cho con chim và sử dụng một kỹ thuật vẽ đặc biệt để áp màu đó lên hình ảnh.

Đây là file Game.java đã được cập nhật:

Java
import java.awt.*;
import java.awt.image.BufferedImage;
import javax.imageio.ImageIO;
import java.io.File;
import java.io.IOException;
import java.util.ArrayList;

public class Game {
    private ArrayList<GameObject> objectList;
    private Bird playerBird;
    private Score score;
    private GameOver gameOver;
    private Leaderboard leaderboard;
    private BufferedImage birdImage; // Thuộc tính để lưu hình ảnh con chim
    private Color birdColor; // Thuộc tính để lưu màu sắc được chọn cho con chim

    public Game() {
        initGame();
        leaderboard = new Leaderboard();
        birdColor = Color.RED; // Màu mặc định ban đầu là đỏ

        // Tải hình ảnh con chim
        try {
            birdImage = ImageIO.read(new File("bird.png")); // Đảm bảo tệp bird.png tồn tại
        } catch (IOException e) {
            System.err.println("Không thể tải hình ảnh con chim: " + e.getMessage());
            // Xử lý lỗi nếu không tải được hình ảnh (ví dụ: vẽ hình tròn mặc định)
        }
    }

    public void initGame() {
        objectList = new ArrayList<>();
        playerBird = new Bird(100, 250, 0); // Bird từ code cũ của bạn
        objectList.add(playerBird);
        objectList.add(new Pipe(600, 300, 5)); // Pipe từ code cũ của bạn
        objectList.add(new Pipe(900, 200, 5));
        score = new Score();
        gameOver = new GameOver();
    }

    // Phương thức để đặt màu sắc cho con chim
    public void setBirdColor(Color color) {
        this.birdColor = color;
    }

    public void jump() {
        if (!gameOver.isGameOver()) {
            playerBird.setVelocity(10); // Nhảy lên
        } else {
            initGame(); // Reset game nếu đang ở màn hình thua
        }
    }

    public void update() {
        if (gameOver.isGameOver()) return;

        // Trọng lực làm chim rơi
        playerBird.setVelocity(playerBird.getVelocity() - 1);

        for (GameObject obj : objectList) {
            obj.move(); // Sử dụng move() gốc của bạn

            if (obj instanceof Pipe) {
                // Check va chạm cơ bản
                if (playerBird.getX() < obj.getX() + 50 && playerBird.getX() + 30 > obj.getX()) {
                    if (playerBird.getY() < obj.getY() - 150 || playerBird.getY() > obj.getY() - 30) {
                        endGame();
                    }
                }
                // Tính điểm khi qua ống
                if (obj.getX() == 100) score.increment();
                // Lặp lại ống
                if (obj.getX() < -50) obj.setX(800);
            }
        }

        if (playerBird.getY() > 550 || playerBird.getY() < 0) endGame();
    }

    private void endGame() {
        gameOver.setGameOver(true);
        leaderboard.addScore(score.getValue());
    }

    public void render(Graphics g) {
        // Nền sky
        g.setColor(new Color(135, 206, 235));
        g.fillRect(0, 0, 800, 600);

        for (GameObject obj : objectList) {
            if (obj instanceof Bird) {
                // Vẽ con chim bằng hình ảnh và áp màu
                if (birdImage != null) {
                    Graphics2D g2d = (Graphics2D) g.create();
                    g2d.drawImage(birdImage, obj.getX(), obj.getY(), 30, 30, null);

                    // Áp màu lên hình ảnh bằng cách vẽ một hình chữ nhật màu đè lên với chế độ hòa trộn
                    g2d.setComposite(AlphaComposite.SrcAtop.derive(0.5f)); // Độ mờ 50%
                    g2d.setColor(birdColor);
                    g2d.fillRect(obj.getX(), obj.getY(), 30, 30);
                    g2d.dispose(); // Giải phóng tài nguyên đồ họa
                } else {
                    // Vẽ hình tròn mặc định nếu không có hình ảnh
                    g.setColor(birdColor);
                    g.fillOval(obj.getX(), obj.getY(), 30, 30);
                }
            } else if (obj instanceof Pipe) {
                g.setColor(Color.GREEN);
                g.fillRect(obj.getX(), obj.getY(), 50, 600); // Ống dưới
                g.fillRect(obj.getX(), 0, 50, obj.getY() - 150); // Ống trên
            }
        }

        // Hiển thị điểm và kỷ lục
        g.setColor(Color.BLACK);
        g.setFont(new Font("Arial", Font.BOLD, 20));
        g.drawString("Score: " + score.getValue(), 20, 30);
        g.drawString("High Score: " + leaderboard.getHighScore(), 20, 60);

        gameOver.draw(g, 800, 600);
    }
}
Giải thích thay đổi:

Chúng ta thêm thuộc tính birdImage để lưu hình ảnh con chim và birdColor để lưu màu sắc được chọn.

Trong constructor, chúng ta tải hình ảnh con chim từ tệp bird.png.

Chúng ta thêm phương thức setBirdColor để cho phép thay đổi màu sắc của con chim từ bên ngoài.

Trong phương thức render, chúng ta thay đổi phần vẽ con chim. Nếu có hình ảnh con chim, chúng ta vẽ hình ảnh đó. Sau đó, chúng ta sử dụng Graphics2D để vẽ một hình chữ nhật màu (với màu được chọn và độ mờ 50%) đè lên hình ảnh con chim bằng chế độ hòa trộn AlphaComposite.SrcAtop. Điều này sẽ tạo ra hiệu ứng áp màu lên hình ảnh con chim. Nếu không có hình ảnh, chúng ta vẽ hình tròn màu mặc định như trước.

3. Thêm một lớp để chọn màu
Chúng ta sẽ tạo một lớp mới có tên ColorPicker.java để hiển thị một cửa sổ cho phép người dùng chọn màu sắc cho con chim. Lớp này sẽ sử dụng JColorChooser của Swing để cung cấp một giao diện chọn màu thân thiện.

ColorPicker.java

Java
import javax.swing.*;
import java.awt.*;
import java.awt.event.ActionEvent;
import java.awt.event.ActionListener;

public class ColorPicker extends JDialog {
    private Game game;
    private JButton chooseColorButton;

    public ColorPicker(Frame owner, Game game) {
        super(owner, "Chọn màu cho con chim", true);
        this.game = game;
        setLayout(new FlowLayout());

        chooseColorButton = new JButton("Chọn màu");
        chooseColorButton.addActionListener(new ActionListener() {
            @Override
            public void actionPerformed(ActionEvent e) {
                Color initialColor = Color.RED; // Màu ban đầu
                Color selectedColor = JColorChooser.showDialog(ColorPicker.this, "Chọn màu", initialColor);
                if (selectedColor != null) {
                    game.setBirdColor(selectedColor);
                    dispose(); // Đóng cửa sổ chọn màu sau khi chọn
                }
            }
        });
        add(chooseColorButton);

        pack();
        setLocationRelativeTo(owner);
    }
}
4. Sửa đổi GameWindow.java để thêm chức năng chọn màu
Chúng ta sẽ thêm một nút "Chọn màu" vào GameWindow.java và hiển thị cửa sổ ColorPicker khi nút này được nhấn.

GameWindow.java

Java
import javax.swing.*;
import java.awt.*;
import java.awt.event.*;

public class GameWindow extends JFrame implements KeyListener {
    private Game game;
    private JButton colorPickerButton; // Nút để mở cửa sổ chọn màu

    public GameWindow() {
        game = new Game();
        setTitle("Flappy Bird Complete with Color Picking");
        setSize(800, 600);
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        addKeyListener(this);
        
        // Tạo panel chứa game
        JPanel gamePanel = new JPanel() {
            @Override
            protected void paintComponent(Graphics g) {
                super.paintComponent(g);
                game.render(g);
            }
        };
        gamePanel.setPreferredSize(new Dimension(800, 600));

        // Tạo nút chọn màu
        colorPickerButton = new JButton("Chọn màu chim");
        colorPickerButton.setFocusable(false); // Ngăn nút chiếm tiêu điểm bàn phím
        colorPickerButton.addActionListener(new ActionListener() {
            @Override
            public void actionPerformed(ActionEvent e) {
                // Hiển thị cửa sổ chọn màu khi nút được nhấn
                ColorPicker colorPicker = new ColorPicker(GameWindow.this, game);
                colorPicker.setVisible(true);
            }
        });

        // Tạo panel để chứa nút chọn màu
        JPanel buttonPanel = new JPanel();
        buttonPanel.add(colorPickerButton);

        // Sử dụng BorderLayout để sắp xếp gamePanel và buttonPanel
        setLayout(new BorderLayout());
        add(gamePanel, BorderLayout.CENTER);
        add(buttonPanel, BorderLayout.SOUTH);

        pack(); // Điều chỉnh kích thước cửa sổ phù hợp với các thành phần bên trong
        setLocationRelativeTo(null); // Hiển thị cửa sổ ở giữa màn hình

        // Vòng lặp game
        new Thread(() -> {
            while (true) {
                game.update();
                gamePanel.repaint();
                try { Thread.sleep(25); } catch (Exception e) {}
            }
        }).start();
    }

    @Override
    public void keyPressed(KeyEvent e) {
        if (e.getKeyCode() == KeyEvent.VK_SPACE) game.jump();
        if (e.getKeyCode() == KeyEvent.VK_R) game.initGame();
    }
    public void keyReleased(KeyEvent e) {}
    public void keyTyped(KeyEvent e) {}

    public static void main(String[] args) {
        // Khởi chạy game
        SwingUtilities.invokeLater(() -> {
            new GameWindow().setVisible(true);
        });
    }
}
Giải thích thay đổi:

Chúng ta thêm một nút colorPickerButton vào GameWindow.java.

Trong constructor, chúng ta tạo nút "Chọn màu chim" và thêm một listener để hiển thị cửa sổ ColorPicker khi nút này được nhấn. Chúng ta cũng sử dụng setFocusable(false) cho nút để ngăn nó chiếm tiêu điểm bàn phím, giúp người dùng vẫn có thể điều khiển con chim bằng phím SPACE ngay cả khi nhấn nút.

Chúng ta sử dụng BorderLayout để sắp xếp gamePanel ở giữa và buttonPanel (chứa nút) ở phía nam (dưới cùng) của cửa sổ.

Chúng ta sử dụng pack() để tự động điều chỉnh kích thước cửa sổ phù hợp với các thành phần bên trong.

5. Chuẩn bị tệp hình ảnh con chim
Đừng quên tạo một tệp hình ảnh con chim (ví dụ: bird.png) và đặt nó vào cùng thư mục với các file Java của bạn. Hình ảnh nên có kích thước nhỏ (ví dụ: 30x30 pixel) và nên có nền trong suốt (transparent background) để trông đẹp mắt hơn khi áp màu.

6. Khởi chạy và trải nghiệm
Bây giờ, bạn có thể khởi chạy GameWindow.java. Bạn sẽ thấy một cửa sổ trò chơi với con chim (hình ảnh) và một nút "Chọn màu chim" ở phía dưới. Bạn có thể chơi trò chơi như bình thường bằng cách nhấn phím SPACE để chim nhảy. Khi bạn muốn đổi màu cho con chim, hãy nhấn nút "Chọn màu chim". Một cửa sổ chọn màu sẽ hiện ra, cho phép bạn chọn màu sắc tùy thích. Sau khi chọn màu và nhấn "Chọn màu", màu sắc của con chim sẽ thay đổi ngay lập tức trong trò chơi.

Với các bước trên, bạn đã thêm được ngoại hình con chim thực thụ và tính năng chọn màu sắc cho con chim mà vẫn giữ nguyên 100% code cũ của bạn. Chúc bạn chơi game vui vẻ!

Bạn đã nói
chưa giống con chim tôi vẫn thấy nó hình tròn

Gemini đã nói
Chào bạn, tôi hiểu rồi. Để con chim thực sự có ngoại hình (hình ảnh) và có thể đổi màu mà vẫn không đụng vào code cũ, chúng ta sẽ sử dụng kỹ thuật "Vẽ đè bằng hình ảnh" trong Java Swing.

Dưới đây là mã nguồn hoàn chỉnh cho các class còn thiếu để chạy thành game:

1. Movable.java (Interface)
Java
public interface Movable {
    void move();
}
2. Score.java (Điểm số)
Java
public class Score {
    private int value = 0;
    public void increment() { value++; }
    public int getValue() { return value; }
    public void reset() { value = 0; }
}
3. Leaderboard.java (Kỷ lục)
Java
public class Leaderboard {
    private int highScore = 0;
    public void check(int score) { if (score > highScore) highScore = score; }
    public int getHighScore() { return highScore; }
}
4. GameOver.java (Trạng thái thua)
Java
import java.awt.*;

public class GameOver {
    public void draw(Graphics g, int score) {
        g.setColor(new Color(0, 0, 0, 150));
        g.fillRect(0, 0, 800, 600);
        g.setColor(Color.WHITE);
        g.setFont(new Font("Arial", Font.BOLD, 40));
        g.drawString("GAME OVER", 280, 250);
        g.setFont(new Font("Arial", Font.PLAIN, 20));
        g.drawString("Điểm của bạn: " + score, 330, 300);
        g.drawString("Bấm 'R' để chơi lại", 315, 350);
    }
}
5. Game.java (Logic & Ngoại hình con chim)
Đây là nơi tôi xử lý việc vẽ con chim thay vì hình tròn. Tôi sử dụng một thủ thuật vẽ đa giác để tạo hình con chim nếu bạn không có file ảnh, hoặc bạn có thể thay bằng drawImage.

Java
import java.awt.*;
import java.util.ArrayList;

public class Game {
    private ArrayList<GameObject> objectList;
    private Bird playerBird;
    private Score score;
    private Leaderboard leaderboard;
    private boolean isLost = false;
    private Color birdColor = Color.YELLOW; // Màu mặc định

    public Game() {
        initGame();
        leaderboard = new Leaderboard();
    }

    public void initGame() {
        objectList = new ArrayList<>();
        playerBird = new Bird(100, 250, 0); 
        objectList.add(playerBird);
        objectList.add(new Pipe(600, 300, 5));
        objectList.add(new Pipe(900, 250, 5));
        score = new Score();
        isLost = false;
    }

    public void setBirdColor(Color c) { this.birdColor = c; }

    public void update() {
        if (isLost) return;
        playerBird.setVelocity(playerBird.getVelocity() - 1); // Trọng lực
        for (GameObject obj : objectList) {
            obj.move();
            if (obj instanceof Pipe) {
                if (obj.getX() < -50) { 
                    obj.setX(800); 
                    score.increment();
                    leaderboard.check(score.getValue());
                }
                // Va chạm
                if (playerBird.getX() + 30 > obj.getX() && playerBird.getX() < obj.getX() + 50) {
                    if (playerBird.getY() < obj.getY() - 150 || playerBird.getY() > obj.getY() - 30) isLost = true;
                }
            }
        }
        if (playerBird.getY() > 550 || playerBird.getY() < 0) isLost = true;
    }

    public void jump() { if (!isLost) playerBird.setVelocity(12); }

    public void render(Graphics g) {
        g.setColor(new Color(135, 206, 235)); // Bầu trời
        g.fillRect(0, 0, 800, 600);

        for (GameObject obj : objectList) {
            if (obj instanceof Bird) {
                drawBird(g, obj.getX(), obj.getY());
            } else if (obj instanceof Pipe) {
                g.setColor(new Color(34, 139, 34));
                g.fillRect(obj.getX(), obj.getY(), 50, 600);
                g.fillRect(obj.getX(), 0, 50, obj.getY() - 150);
            }
        }
        
        g.setColor(Color.BLACK);
        g.drawString("Điểm: " + score.getValue(), 20, 30);
        g.drawString("Kỷ lục: " + leaderboard.getHighScore(), 20, 50);
        if (isLost) new GameOver().draw(g, score.getValue());
    }

    // Hàm vẽ con chim có hình dạng (Mỏ, cánh, mắt)
    private void drawBird(Graphics g, int x, int y) {
        Graphics2D g2 = (Graphics2D) g;
        // Thân chim
        g2.setColor(birdColor);
        g2.fillOval(x, y, 35, 30);
        // Cánh
        g2.setColor(Color.WHITE);
        g2.fillOval(x + 5, y + 10, 15, 10);
        // Mắt
        g2.setColor(Color.BLACK);
        g2.fillOval(x + 25, y + 5, 5, 5);
        // Mỏ
        g2.setColor(Color.ORANGE);
        int[] mx = {x + 33, x + 43, x + 33};
        int[] my = {y + 10, y + 15, y + 20};
        g2.fillPolygon(mx, my, 3);
    }
}
6. GameWindow.java (Giao diện & Chọn màu)
Tôi thêm các nút chọn màu ở phía dưới để bạn bấm vào là chim đổi màu ngay.

Java
import javax.swing.*;
import java.awt.*;
import java.awt.event.*;

public class GameWindow extends JFrame implements KeyListener {
    private Game game;

    public GameWindow() {
        game = new Game();
        setTitle("Flappy Bird Custom");
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        
        JPanel gamePanel = new JPanel() {
            @Override
            protected void paintComponent(Graphics g) {
                super.paintComponent(g);
                game.render(g);
            }
        };
        gamePanel.setPreferredSize(new Dimension(800, 600));

        // Thanh chọn màu
        JPanel colorPanel = new JPanel();
        colorPanel.add(new JLabel("Chọn màu chim: "));
        String[] colors = {"Vàng", "Đỏ", "Xanh", "Hồng"};
        Color[] colorValues = {Color.YELLOW, Color.RED, Color.CYAN, Color.PINK};
        
        for (int i = 0; i < colors.length; i++) {
            JButton btn = new JButton(colors[i]);
            final int index = i;
            btn.addActionListener(e -> {
                game.setBirdColor(colorValues[index]);
                gamePanel.requestFocusInWindow();
            });
            btn.setFocusable(false);
            colorPanel.add(btn);
        }

        add(gamePanel, BorderLayout.CENTER);
        add(colorPanel, BorderLayout.SOUTH);
        pack();
        
        gamePanel.setFocusable(true);
        gamePanel.addKeyListener(this);
        setLocationRelativeTo(null);

        new Thread(() -> {
            while (true) {
                game.update();
                gamePanel.repaint();
                try { Thread.sleep(25); } catch (Exception e) {}
            }
        }).start();
    }

    @Override
    public void keyPressed(KeyEvent e) {
        if (e.getKeyCode() == KeyEvent.VK_SPACE) game.jump();
        if (e.getKeyCode() == KeyEvent.VK_R) game.initGame();
    }
    public void keyReleased(KeyEvent e) {}
    public void keyTyped(KeyEvent e) {}

    public static void main(String[] args) {
        new GameWindow().setVisible(true);
    }
}
Kết quả cuối cùng:
Ngoại hình: Trong hàm drawBird, tôi đã dùng code để vẽ thêm cánh, mỏ và mắt cho con chim, nhìn sẽ giống một con chim thật hơn là một hình tròn đỏ.

Chọn màu: Bạn có các nút "Vàng", "Đỏ", "Xanh" ở dưới màn hình. Bấm vào nút nào con chim sẽ đổi sang màu đó ngay lập tức.

Code cũ: Tôi hoàn toàn không sửa file Bird.java hay Pipe.java của bạn.

Bạn hãy copy các file này vào dự án, sau đó Run file GameWindow.java nhé!

