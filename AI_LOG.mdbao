✅ Thể hiện kế thừa

✅ Dùng polymorphism

✅ Không tiếng Viet co dau

✅ VERSION MAIN DAT YEU CAU
import java.util.ArrayList;
import java.util.Scanner;

public class Main {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);
        ArrayList<GameObject> objectList = new ArrayList<GameObject>();

        System.out.print("Enter number of objects: ");
        int n = Integer.parseInt(sc.nextLine());

        for (int i = 0; i < n; i++) {

            System.out.println("1. Bird");
            System.out.println("2. Pipe");
            System.out.print("Choose type: ");
            int choice = Integer.parseInt(sc.nextLine());

            System.out.print("Enter x: ");
            int x = Integer.parseInt(sc.nextLine());

            System.out.print("Enter y: ");
            int y = Integer.parseInt(sc.nextLine());

            if (choice == 1) {

                System.out.print("Enter velocity: ");
                int velocity = Integer.parseInt(sc.nextLine());

                GameObject bird = new Bird(x, y, velocity);
                objectList.add(bird);

            } else if (choice == 2) {

                System.out.print("Enter speed: ");
                int speed = Integer.parseInt(sc.nextLine());

                GameObject pipe = new Pipe(x, y, speed);
                objectList.add(pipe);
            }
        }

        System.out.println("=== Before Move ===");
        for (GameObject obj : objectList) {
            obj.display();
        }

        System.out.println("=== After Move ===");
        for (GameObject obj : objectList) {

            if (obj instanceof Bird) {
                ((Bird) obj).flyUp();
            }

            if (obj instanceof Pipe) {
                ((Pipe) obj).moveLeft();
            }

            obj.display();
        }

        sc.close();
    }
}
🎯 Check theo tieu chi thay
Yeu cau	Trang thai
Quan ly danh sach	✅
Nhap tu ban phim	✅
parseInt(nextLine())	✅
Ke thua	✅
Polymorphism	✅
Khong nextInt()	✅
JDK 1.8 compatible	✅
Nếu thầy muốn version cao cấp hơn (khong dung instanceof, dung abstract method move()) thì nói anh, anh nâng cấp lên bản an diem cao hon nữa.


